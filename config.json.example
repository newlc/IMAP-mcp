{
  "_comment": "Multi-account config. Each entry under accounts[] is one independent IMAP/SMTP account with its own cache. Mark exactly one with default:true (skipped if there's only one). Leave credentials.password empty and run 'imap-mcp --set-password --account <name>' to store the password in the OS keyring.",

  "accounts": [
    {
      "name": "work",
      "default": true,

      "imap": {
        "host": "imap.work.example.com",
        "port": 993,
        "secure": true
      },
      "smtp": {
        "host": "smtp.work.example.com",
        "port": 587,
        "secure": false,
        "starttls": true
      },
      "sieve": {
        "host": "sieve.work.example.com",
        "port": 4190,
        "starttls": true
      },

      "credentials": {
        "username": "you@work.example.com",
        "password": ""
      },

      "user": {
        "name": "Your Name",
        "email": "you@work.example.com",
        "signature": {
          "enabled": true,
          "text": "\n\n--\nYour Name\nWork",
          "html": "<br><br><div style=\"color:#666\">--<br><b>Your Name</b><br>Work</div>"
        }
      },

      "folders": {
        "inbox": "INBOX",
        "next": "Next",
        "waiting": "Waiting",
        "someday": "Someday",
        "archive": "Archive",
        "drafts": "Drafts",
        "sent": "Sent",
        "trash": "Trash",
        "spam": "Spam"
      },

      "cache": {
        "enabled": true,
        "ttl_seconds": 300,
        "db_path": "~/.imap-mcp/work.db",
        "encrypt": true
      },

      "spam": {
        "junk_flag": "$Junk",
        "not_junk_flag": "$NotJunk"
      },

      "security": {
        "max_attachment_size_mb": 25,
        "attachments_allowed_dirs": [
          "~/Documents",
          "~/Downloads"
        ]
      },

      "auto_archive": {
        "enabled": true,
        "senders_file": "auto_archive_work.json"
      }
    },

    {
      "name": "personal",

      "imap": {
        "host": "imap.personal.example.com",
        "port": 993,
        "secure": true
      },
      "smtp": {
        "host": "smtp.personal.example.com",
        "port": 465,
        "secure": true
      },

      "credentials": {
        "username": "you@personal.example.com",
        "password": ""
      },

      "user": {
        "name": "Your Name",
        "email": "you@personal.example.com"
      },

      "folders": {
        "inbox": "INBOX",
        "drafts": "Drafts",
        "sent": "Sent",
        "trash": "Trash",
        "spam": "Spam",
        "archive": "Archive"
      },

      "cache": {
        "enabled": false,
        "db_path": "~/.imap-mcp/personal.db",
        "encrypt": false
      }
    }
  ]
}
